
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    match /packages/{packageId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /resultGalleryItems/{galleryItemId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /contentLibrary/{videoId} {
      allow get, list: if true;
      allow create, update, delete: if false; // Assuming uploads are managed via server/admin
    }
  }
}
