
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and their registration details for a service package within the She is Fit application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity. This typically mirrors the authenticated user's ID."
        },
        "fullName": {
          "type": "string",
          "description": "The full name of the user as provided during registration."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "healthProfile": {
          "type": "object",
          "properties": {
            "allergies": { "type": "string" },
            "injuryHistory": { "type": "string" }
          },
          "required": ["allergies", "injuryHistory"]
        },
        "subscriptionStatus": {
          "type": "string",
          "description": "The current status of the user's package subscription (e.g., 'pending', 'active', 'cancelled')."
        },
        "packageId": {
          "type": "string",
          "description": "Reference to the Package the user has registered for."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "fullName",
        "email",
        "healthProfile",
        "subscriptionStatus",
        "packageId",
        "createdAt"
      ]
    },
    "Package": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Package",
      "type": "object",
      "description": "Defines an exercise package offered by She is Fit.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string", "format": "uri" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "description", "price", "imageUrl", "isActive"]
    },
    "ResultGalleryItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ResultGalleryItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "beforeImageUrl": { "type": "string", "format": "uri" },
        "afterImageUrl": { "type": "string", "format": "uri" },
        "testimonial": { "type": "string" }
      },
      "required": ["id", "beforeImageUrl", "afterImageUrl", "testimonial"]
    },
    "ContentLibraryItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ContentLibraryItem",
      "type": "object",
      "description": "Represents a video content entry in the She is Fit library.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "description": { "type": "string" },
        "muscleGroups": { "type": "array", "items": { "type": "string" } },
        "season": { "type": "string", "enum": ["Verano", "Navidad"] },
        "duration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "videoUrl", "thumbnailUrl", "description", "muscleGroups", "season", "duration", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/packages/{packageId}",
        "definition": {
          "entityName": "Package",
          "schema": { "$ref": "#/backend/entities/Package" },
          "description": "Stores publicly viewable exercise packages."
        }
      },
      {
        "path": "/resultGalleryItems/{galleryItemId}",
        "definition": {
          "entityName": "ResultGalleryItem",
          "schema": { "$ref": "#/backend/entities/ResultGalleryItem" },
          "description": "Stores transformation results."
        }
      },
      {
        "path": "/contentLibrary/{videoId}",
        "definition": {
          "entityName": "ContentLibraryItem",
          "schema": { "$ref": "#/backend/entities/ContentLibraryItem" },
          "description": "Library of workout videos and educational content."
        }
      }
    ]
  }
}
